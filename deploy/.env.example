# ─────────────────────────────────────────────────────────────────────────────
# NexEx Production Environment Variables
# Copy this file to deploy/.env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL database password (choose a strong random password)
POSTGRES_PASSWORD=change_me_to_a_strong_password_here

# Express session secret (random 64-char string, e.g. `openssl rand -hex 32`)
SESSION_SECRET=change_me_to_a_random_64char_hex_string

# Admin panel password — must be a bcrypt hash!
# To generate: node -e "const b=require('bcryptjs'); b.hash('YourPassword',12).then(console.log)"
ADMIN_PASSWORD=$2b$12$examplehash_replace_with_real_bcrypt_hash

# HD Wallet mnemonic (12 or 24 words) — used to derive deposit addresses
# WARNING: keep this secret, controls all user deposit wallets
WALLET_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Hot wallet private key (0x-prefixed) — used to send on-chain withdrawals
# WARNING: this wallet needs ETH/BNB/MATIC for gas fees
HOT_WALLET_PRIVATE_KEY=0xyour_private_key_here
